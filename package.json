{
  "name": "@zap-simon/beacon-login",
  "version": "1.0.0",
  "description": "Reusable beacon-backed login UI and auth helpers for Next.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./styles.css": "./dist/styles/theme.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp -r src/styles dist/styles",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "next": "^16",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^5"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zap-simon/beacon-login.git"
  },
  "license": "UNLICENSED",
  "private": false
}
